# Copy to .env (or set these in your host's dashboard) for production.
PORT=4000
# A long random string — used to sign login tokens. CHANGE THIS in production.
JWT_SECRET=please-change-me-to-a-long-random-string
# Where the SQLite file lives. On a host with a persistent disk, point this at it,
# e.g. DB_PATH=/data/data.sqlite
DB_PATH=
